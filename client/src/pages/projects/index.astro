---
import { getCollection } from 'astro:content';
import CreativeLayout from '../../layouts/CreativeLayout.astro';
import IncidentCard from '@features/projects/IncidentCard.astro';
import { ActiveServices } from '@features/projects/ActiveServices';

// Fetch Monitored Incidents (Tier 1)
const projects = await getCollection('projects');

// Sort by start date (newest first), ensuring timeline.start is parsed as Date
const sortedIncidents = projects.sort((a, b) => {
    const dateA = new Date(a.data.timeline.start).getTime();
    const dateB = new Date(b.data.timeline.start).getTime();
    return dateB - dateA;
});
---

<CreativeLayout title="Jeremy Garin | Projects" description="System Registry — incident reports and case studies covering DevOps, AI/ML, and full-stack systems. Each project includes root-cause analysis and architecture details." ogType="article">
    <div class="min-h-screen pt-24 pb-24 px-4 bg-[#050505] relative font-mono text-sm">
        
        {/* Background Grid Texture */}
        <div class="absolute inset-0 opacity-[0.02] pointer-events-none" style="background-image: linear-gradient(rgba(255, 255, 255, 1) 1px, transparent 1px), linear-gradient(90deg, rgba(255, 255, 255, 1) 1px, transparent 1px); background-size: 40px 40px;"></div>

        <div class="max-w-6xl mx-auto relative z-10 flex flex-col gap-16">
            
            {/* PAGE HEADER */}
            <header class="border-b border-white/10 pb-8 flex flex-col items-center text-center md:items-start md:text-left">
               <h1 class="text-[10px] md:text-xs uppercase tracking-[0.3em] text-white/30 mb-2">CATALOG_OF_SERVICES</h1>
               <h2 class="text-3xl md:text-5xl font-bold font-display text-white tracking-tight">SYSTEM_REGISTRY</h2>
               <p class="mt-4 text-primary/50 max-w-2xl text-xs md:text-sm leading-relaxed">
                   A comprehensive index of deployed infrastructure, archived prototypes, and active system integrations. Classified incidents contain detailed root-cause analysis reports.
               </p>
            </header>

            {/* SECTION 1: MONITORED INCIDENTS */}
            <section>
                <div class="flex items-center gap-4 mb-8">
                    <div class="h-px bg-white/10 flex-1"></div>
                    <h3 class="text-emerald-500 font-bold tracking-[0.2em] uppercase text-xs flex items-center gap-2">
                        <span class="w-1.5 h-1.5 rounded-full bg-emerald-500 animate-pulse"></span>
                        TIER_1 // MONITORED_INCIDENTS
                    </h3>
                    <div class="h-px bg-white/10 flex-1 md:hidden"></div>
                </div>
                
                <div class="grid grid-cols-1 md:grid-cols-2 gap-6" id="incidents-grid">
                    {sortedIncidents.map((project, index) => (
                        <div class={`incident-wrapper ${index >= 4 ? 'hidden' : ''}`}>
                            <IncidentCard project={project} />
                        </div>
                    ))}
                </div>

                {sortedIncidents.length > 4 && (
                    <div class="mt-8 flex justify-center" id="load-more-container">
                        <button id="load-more-btn" class="px-6 py-3 bg-white/5 text-slate-300 border border-white/10 hover:bg-white/10 transition-colors uppercase tracking-widest text-sm font-bold flex items-center gap-3">
                            <span class="text-emerald-500">↓</span>
                            [ DECRYPT ADDITIONAL RECORDS ]
                        </button>
                    </div>
                )}
            </section>

            {/* SECTION 2: ACTIVE SERVICES */}
            <section>
                <div class="flex items-center gap-4 mb-8">
                    <div class="h-px bg-white/10 flex-1"></div>
                    <h3 class="text-cyan-500 font-bold tracking-[0.2em] uppercase text-xs flex items-center gap-2">
                        <span class="text-cyan-500">➜</span>
                        TIER_2 // ACTIVE_SERVICES
                    </h3>
                    <div class="h-px bg-white/10 flex-1 md:hidden"></div>
                </div>
                
                <div class="bg-[#0a0a0c] border border-white/5 p-4 md:p-6 shadow-2xl relative overflow-hidden">
                     {/* Data fetching component */}
                     <ActiveServices client:load />
                </div>
            </section>

        </div>
    </div>
</CreativeLayout>

<script>
    const loadMoreBtn = document.getElementById('load-more-btn');
    const container = document.getElementById('load-more-container');
    
    if (loadMoreBtn && container) {
        let currentShown = 4;
        loadMoreBtn.addEventListener('click', () => {
            const allWrappers = document.querySelectorAll('.incident-wrapper');
            const hiddenWrappers = document.querySelectorAll('.incident-wrapper.hidden');
            
            // Show the next 4 cards (or however many are left)
            const nextBatch = Array.from(hiddenWrappers).slice(0, 4);
            nextBatch.forEach(el => el.classList.remove('hidden'));
            
            currentShown += nextBatch.length;
            
            // Hide the button if all cards are shown
            if (currentShown >= allWrappers.length) {
                container.style.display = 'none';
            }
        });
    }
</script>
