---
import type { CollectionEntry } from "astro:content";

interface Props {
  project: CollectionEntry<"projects">;
}

const { project } = Astro.props;

const getImpactColor = (level: string) => {
    switch(level) {
        case 'CRITICAL': return 'text-red-500 border-red-500/30 bg-red-500/10 group-hover:bg-red-500/20';
        case 'HIGH': return 'text-orange-500 border-orange-500/30 bg-orange-500/10 group-hover:bg-orange-500/20';
        default: return 'text-emerald-500 border-emerald-500/30 bg-emerald-500/10 group-hover:bg-emerald-500/20';
    }
};

const getTextColor = (level: string) => {
    switch(level) {
        case 'CRITICAL': return 'text-red-400 group-hover:text-red-300';
        case 'HIGH': return 'text-orange-400 group-hover:text-orange-300';
        default: return 'text-emerald-400 group-hover:text-emerald-300';
    }
};
---

<a 
  href={`/projects/${project.slug}`}
  class="group block bg-white/5 border border-white/10 hover:border-white/20 transition-all duration-300 relative overflow-hidden"
>
  {/* TOP DECORATION */}
  <div class={`h-1 w-full ${getImpactColor(project.data.impact_level)} opacity-50`}></div>

  <div class="p-6 md:p-8 relative z-10">
    <div class="flex flex-col md:flex-row md:items-start justify-between gap-4 mb-6">
      
      {/* IDENTITY */}
      <div>
        <div class="flex items-center gap-3 mb-2">
           <span class="text-[10px] font-mono tracking-[0.2em] text-white/50 bg-white/5 px-2 py-0.5 rounded-sm uppercase">
              {project.data.impact_level} IMPACT
           </span>
           <span class={`text-xs font-mono font-bold tracking-widest ${getTextColor(project.data.impact_level)}`}>
              {project.data.status}
           </span>
        </div>
        <h3 class="text-2xl font-bold font-display tracking-tight text-white mb-1 uppercase">
          {project.data.title}
        </h3>
        <p class="text-xs font-mono text-primary/50 tracking-widest uppercase">
          REPORT_ID: {project.data.incident_id}
        </p>
      </div>

      {/* SYSTEMS AFFECTED */}
      <div class="flex md:justify-end gap-2 flex-wrap">
        {project.data.affected_systems.slice(0, 3).map(sys => (
           <span class="text-[9px] font-mono border border-primary/20 text-primary/60 px-1.5 py-0.5 whitespace-nowrap">
             {sys}
           </span>
        ))}
        {project.data.affected_systems.length > 3 && (
           <span class="text-[9px] font-mono border border-primary/20 text-primary/60 px-1.5 py-0.5 whitespace-nowrap">
             +{project.data.affected_systems.length - 3}
           </span>
        )}
      </div>

    </div>

    {/* ROOT CAUSE SUMMARY */}
    <div class="bg-black/20 border-l-2 border-primary/20 p-4">
       <span class="block text-[10px] text-primary/40 font-mono tracking-widest mb-2 uppercase">Root Cause Summary:</span>
       <p class="text-sm font-sans font-light text-primary/80 line-clamp-2">
         {project.data.root_cause}
       </p>
    </div>

    {/* FOOTER METADATA */}
    <div class="mt-6 flex items-center justify-between border-t border-white/5 pt-4">
        <div class="text-[10px] font-mono text-white/30 uppercase tracking-[0.2em]">
           {project.data.resolution}
        </div>
        <div class="text-xs text-primary font-mono opacity-0 group-hover:opacity-100 transition-opacity transform translate-x-4 group-hover:translate-x-0 duration-300">
           ACCESS REPORT ➜
        </div>
    </div>
  </div>

  {/* HOVER GLOW EFFECT */}
  <div class={`absolute inset-0 z-0 bg-gradient-to-br from-${getImpactColor(project.data.impact_level).split(' ')[0].replace('text-', '')}/5 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500 pointer-events-none`}></div>
</a>
