---
import '../styles/global.css';
import { ClientRouter } from 'astro:transitions';
import { NavigationSwitcher } from '../components/layouts/NavigationSwitcher';

interface Props {
  title?: string;
}

const { title = "Jeremy Garin | Portfolio" } = Astro.props;
const currentPath = Astro.url.pathname;

const activeClass = "bg-white/10 text-white";
const inactiveClass = "text-text-muted hover:text-white";
---

<!doctype html>
<html lang="en" class="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg?v=2" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">
    <ClientRouter />
  </head>
  <body class="min-h-screen font-sans text-text-primary antialiased selection:bg-primary/30 selection:text-white pb-10">
    
    {/* Floating Navigation */}
    <nav class="fixed top-6 left-0 right-0 z-50 flex justify-center sm:justify-center pointer-events-none px-4">
      <NavigationSwitcher currentPath={currentPath} client:load />
    </nav>

    {/* Main Content Area */}
    <main class="relative z-10 min-h-screen w-full">
      <slot />
    </main>

    {/* Fixed Status Bar Footer */}
    <footer class="fixed bottom-0 left-0 right-0 z-50 flex h-8 items-center justify-between border-t border-white/10 bg-[#0f1117]/80 px-4 text-[10px] font-mono text-text-muted backdrop-blur-sm">
      <div class="flex items-center gap-4">
        <div class="flex items-center gap-1.5">
          <span class="h-2 w-2 rounded-full bg-primary/50"></span>
          <span>main</span>
        </div>
        <div class="flex items-center gap-1.5">
          <span>⊗ 0</span>
          <span>⚠ 0</span>
        </div>
      </div>
      <div class="flex items-center gap-4">
        <span class="hidden sm:inline">Ln 1, Col 1</span>
        <span class="hidden sm:inline">UTF-8</span>
        <div class="flex items-center gap-2" title="Live Connection">
            <span class="relative flex h-2 w-2">
              <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-emerald-400 opacity-75"></span>
              <span class="relative inline-flex rounded-full h-2 w-2 bg-emerald-500"></span>
            </span>
        </div>
      </div>
    </footer>

    {/* Ambient Background Glows */}
    <div class="fixed inset-0 pointer-events-none z-0">
        <div class="absolute top-1/4 left-1/4 h-96 w-96 rounded-full bg-primary/10 blur-[100px]"></div>
        <div class="absolute bottom-1/4 right-1/4 h-96 w-96 rounded-full bg-success/5 blur-[100px]"></div>
    </div>
    
    <style is:global>
      .scanline-text {
        position: relative;
        overflow: hidden;
      }
      .scanline-text::after {
        content: "";
        position: absolute;
        inset: 0;
        background: repeating-linear-gradient(
          to bottom,
          transparent 0px,
          transparent 2px,
          rgba(255, 255, 255, 0.05) 3px
        );
        pointer-events: none;
        mix-blend-mode: overlay;
      }
      .no-scrollbar::-webkit-scrollbar {
        display: none;
      }
      .no-scrollbar {
        -ms-overflow-style: none;  /* IE and Edge */
        scrollbar-width: none;  /* Firefox */
      }
    </style>
  </body>
</html>
