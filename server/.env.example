# Flask
FLASK_APP=run.py
PORT=5000

# CORS — set to your frontend URL in production (e.g. https://portfolio.pages.dev)
CORS_ORIGINS=*

# Simulation parameters
SIM_CPU_MIN=10
SIM_CPU_MAX=70
SIM_MEM_MIN=20
SIM_MEM_MAX=80
SIM_OFFLINE_RATE=0.02
SIM_DEGRADED_RATE=0.12
SIM_LATENCY_CHANCE=0.1
SIM_LATENCY_MS=500
SIM_BUCKET_SECONDS=30

# Deployment metadata (injected by CI pipeline, safe to leave empty locally)
APP_VERSION=local
APP_BUILD_TIME=

# Runtime config (exposed via /api/config)
CONFIG_DEBUG_MODE=false
CONFIG_TRAFFIC_LEVEL=low
CONFIG_SIM_MODE=standard
